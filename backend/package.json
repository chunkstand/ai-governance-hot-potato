{
  "name": "ai-arena-backend",
  "version": "1.1.0",
  "description": "AI Governance Arena - Backend API for real-time AI agent competition",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.1",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "ai",
    "governance",
    "arena",
    "multiplayer",
    "game"
  ],
  "author": "AgentGameworks",
  "license": "MIT"
}
