# AI Arena Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=development

# Server Port
PORT=3000

# Database Connection (PostgreSQL required)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/aiarena

# CORS Origin (frontend URL)
# In production: https://chunkstand.github.io
# In development: http://localhost:3000 or http://localhost:5173
CORS_ORIGIN=http://localhost:3000

# WebSocket CORS Origin (defaults to CORS_ORIGIN if not set)
# Set this if WebSocket connections need different origin than HTTP
SOCKET_CORS_ORIGIN=http://localhost:3000

# AI API Keys (required for Phase 5 - AI Integration)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# AI Cost Controls
# Daily alert threshold in USD (default: 10)
AI_DAILY_COST_ALERT_USD=10

# Per-game hard cap in USD (default: 2)
AI_GAME_COST_CAP_USD=2
