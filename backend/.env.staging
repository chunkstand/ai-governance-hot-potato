# AI Arena Backend - Staging Environment Configuration
NODE_ENV=staging
PORT=3000

# CORS Origin (GitHub Pages frontend)
CORS_ORIGIN=https://chunkstand.github.io

# Database Connection (from Render dashboard)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://aiarena:password@your-staging-db.render.com:5432/aiarena_staging

# AI API Keys (set manually in Render dashboard)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
